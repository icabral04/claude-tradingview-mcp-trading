# Deribit API credentials
# Obtenha em: Deribit → Account → API Keys
# Permissões necessárias: read, trade (sem withdraw)
DERIBIT_CLIENT_ID=your_client_id_here
DERIBIT_CLIENT_SECRET=your_client_secret_here

# Segredo do webhook do TradingView (opcional mas recomendado)
WEBHOOK_SECRET=meu_segredo_aqui

# Paper trading: "true" = apenas simula ordens, não envia para a Deribit
# Mude para "false" somente após validar a estratégia
PAPER_TRADING=true

# Mesmo em PAPER_TRADING=true, ler conta e posições reais do Deribit
# (não afeta envio de ordens). Útil para ver saldo/posições sem risco.
USE_REAL_ACCOUNT_DATA=false
